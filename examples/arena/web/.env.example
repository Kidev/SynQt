# The edge's secrets. Copy this file to web/.env (git-ignored) and fill it in. The client
# secret lives ONLY here, on the edge; it never goes in synqt.yaml and never anywhere the
# browser can reach (docs/tutorial-multiplayer-world.md, docs/tutorial-sign-in.md).
GITHUB_CLIENT_SECRET=your-generated-secret
