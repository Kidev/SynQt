#
# Doxygen configuration for the SynQt C++ runtime reference.
#
# Build it on its own:      doxygen Doxyfile        (output in build/apidocs/html)
# Build it with the site:   mkdocs build            (output under the site's /api/)
#
# The MkDocs hook in tools/docs-hooks/doxygen_hook.py overrides OUTPUT_DIRECTORY so the
# generated HTML lands inside the documentation site. Everything else comes from here.

PROJECT_NAME           = "SynQt"
PROJECT_BRIEF          = "C++ runtime reference"
PROJECT_LOGO           = docs/assets/synqt.svg
OUTPUT_DIRECTORY       = build/apidocs
OUTPUT_LANGUAGE        = English

# The runtime libraries only. The tooling is Python, the tests and benchmarks are
# fixtures, and neither belongs in a reference of the public runtime surface.
INPUT                  = src tools/docs-hooks/apidocs-mainpage.md
FILE_PATTERNS          = *.h *.cpp *.md
USE_MDFILE_AS_MAINPAGE = tools/docs-hooks/apidocs-mainpage.md
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/* */generated/*

# Every class and member appears, documented or not, so the reference is a complete map
# of the runtime rather than a partial one that silently omits whatever lacks a comment.
EXTRACT_ALL            = YES
EXTRACT_STATIC         = YES
# Private members are implementation, not reference material: they are the one thing a
# reader of this reference cannot call.
EXTRACT_PRIVATE        = NO
EXTRACT_LOCAL_CLASSES  = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO

# The headers document with `///` blocks whose first sentence is the brief.
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = YES
MULTILINE_CPP_IS_BRIEF = NO
INHERIT_DOCS           = YES
SORT_MEMBER_DOCS       = NO
SORT_BRIEF_DOCS        = NO

# Qt's moc keywords are not C++ and would otherwise be parsed as identifiers.
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = YES
PREDEFINED             = Q_OBJECT= \
                         Q_GADGET= \
                         Q_PROPERTY(x)= \
                         Q_INVOKABLE= \
                         Q_ENUM(x)= \
                         Q_DECLARE_METATYPE(x)= \
                         Q_SIGNALS=signals \
                         Q_SLOTS=slots \
                         Q_EMIT= \
                         QT_BEGIN_NAMESPACE= \
                         QT_END_NAMESPACE=

BUILTIN_STL_SUPPORT    = YES
GENERATE_TODOLIST      = NO
GENERATE_TESTLIST      = NO
GENERATE_BUGLIST       = NO
GENERATE_DEPRECATEDLIST = NO

# Warn about anything the parser cannot make sense of, but do not fail a docs build on a
# missing comment: EXTRACT_ALL already covers those, and the site must still publish.
QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html

# doxygen-awesome-css (MIT, vendored under tools/docs-hooks/doxygen-awesome, see the
# VERSION and LICENSE files there), in its sidebar-only layout: the treeview is the only
# navigation, which gives the content the full width. The theme requires
# HTML_COLORSTYLE = LIGHT and FULL_SIDEBAR = NO; dark mode is not Doxygen's, it is the
# theme's own, pinned on by `class="dark-mode"` in the header so the reference matches
# the dark-only documentation site.
HTML_HEADER            = tools/docs-hooks/doxygen-header.html
HTML_EXTRA_STYLESHEET  = tools/docs-hooks/doxygen-awesome/doxygen-awesome.css \
                         tools/docs-hooks/doxygen-awesome/doxygen-awesome-sidebar-only.css \
                         tools/docs-hooks/doxygen-synqt.css
HTML_EXTRA_FILES       = tools/docs-hooks/doxygen-awesome/doxygen-awesome-fragment-copy-button.js \
                         tools/docs-hooks/doxygen-awesome/doxygen-awesome-paragraph-link.js \
                         tools/docs-hooks/doxygen-awesome/doxygen-awesome-interactive-toc.js \
                         tools/docs-hooks/doxygen-awesome/doxygen-awesome-tabs.js
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
HTML_COPY_CLIPBOARD    = NO
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 335
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
SEARCHENGINE           = YES

GENERATE_LATEX         = NO
GENERATE_XML           = NO

# Collaboration and inheritance graphs, when Graphviz is present. Without `dot` doxygen
# falls back to plain text lists rather than failing.
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = NO
INCLUDED_BY_GRAPH      = NO
CALL_GRAPH             = NO
CALLER_GRAPH           = NO
DOT_GRAPH_MAX_NODES    = 60
