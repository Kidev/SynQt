{
    "version": 3,
    "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
    "configurePresets": [
        {
            "name": "m0-edge",
            "displayName": "M0 edge (native, host Qt kit)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/../../build/m0-edge",
            "cacheVariables": {
                "SYNQT_M0_ENTITY": "edge",
                "CMAKE_BUILD_TYPE": "RelWithDebInfo",
                "CMAKE_PREFIX_PATH": "/opt/Qt/6.11.1/gcc_64"
            }
        },
        {
            "name": "m0-client",
            "displayName": "M0 client (WASM single-threaded)",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/../../build/m0-client",
            "toolchainFile": "/opt/Qt/6.11.1/wasm_singlethread/lib/cmake/Qt6/qt.toolchain.cmake",
            "cacheVariables": {
                "SYNQT_M0_ENTITY": "client",
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        { "name": "m0-edge", "configurePreset": "m0-edge" },
        { "name": "m0-client", "configurePreset": "m0-client" }
    ]
}
